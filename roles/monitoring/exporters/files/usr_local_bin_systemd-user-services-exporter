#!/bin/bash
# collects the active/failed state of systemd user services, for users which have logind session lingering enabled
# Example output:
# $ sudo cat /var/lib/node_exporter/textfile_collector/systemd_user_services.prom
# systemd_user_service_state{user="live",service="archiver.service",active="failed"} 1
# systemd_user_service_state{user="live",service="dbus.service",active="active"} 0
# systemd_user_service_state{user="live",service="dirmngr.service",active="active"} 0
# systemd_user_service_state{user="live",service="gpg-agent.service",active="inactive"} 0
# systemd_user_service_state{user="live",service="keyboxd.service",active="inactive"} 0
# systemd_user_service_state{user="live",service="ssh-agent.service",active="inactive"} 0


TEXTFILE_DIR="/var/lib/node_exporter/textfile_collector"
OUTPUT_FILE="$TEXTFILE_DIR/systemd_user_services.prom"

mkdir -p "$TEXTFILE_DIR"

{
    for user_file in /var/lib/systemd/linger/*; do
        [ -f "$user_file" ] || continue
        username=$(basename "$user_file")
        uid=$(id -u "$username" 2>/dev/null) || continue
        
        sudo -u "$username" XDG_RUNTIME_DIR="/run/user/$uid" \
            systemctl --user list-units --type=service --all --plain --no-legend 2>/dev/null | \
            awk -v user="$username" '{
                state = ($3 == "failed") ? 1 : 0
                printf "systemd_user_service_state{user=\"%s\",service=\"%s\",active=\"%s\"} %d\n", user, $1, $3, state
            }'
    done
} > "$OUTPUT_FILE.$$" && mv "$OUTPUT_FILE.$$" "$OUTPUT_FILE"
